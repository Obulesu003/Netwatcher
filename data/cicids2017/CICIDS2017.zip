.cloud-free-trial .free-trial-component {
  align-items: center;
  background: linear-gradient(90deg, var(--devsite-ref-palette--blue50) 0%,
    var(--devsite-ref-palette--green50) 100%);
    border-radius: 10px;
    display: grid;
    gap: 28px;
    grid: auto-flow / auto 1fr;
    padding: 14px 40px;
  }

[theme="clouddocs-theme"] .cloud-free-trial .free-trial-component {
  border-radius: 0;
  display: flex;
  flex-direction: row-reverse;
  gap: 40px;
  margin: 0 -40px;
  padding: 40px;
}

.cloud-free-trial .free-trial-description h4 {
  font: 500 18px var(--devsite-heading-font-family);
  margin-bottom: 4px;
}

.cloud-free-trial .free-trial-description ul {
  padding-inline-start: 18px;
}

.cloud-free-trial .free-trial-description li:not(:last-of-type) {
  padding-bottom: 4px;
}

.cloud-free-trial .free-trial-description p,
.cloud-free-trial .free-trial-description li {
  font-size: 14px;
  line-height: 18px;
  margin: 0;
}

.cloud-free-trial .free-trial-button-wrapper {
  display: flex;
  flex: 1;
}

.cloud-free-trial .free-trial-button-wrapper .button {
  margin: 0 auto;
}

.color-scheme--dark .cloud-free-trial .free-trial-component {
  background: linear-gradient(90deg, var(--devsite-ref-palette--blue400) 0%,
    var(--devsite-ref-palette--green400) 100%);
}

@media screen and (max-width: 600px) {
  .cloud-free-trial .free-trial-component {
    display: flex;
    flex-direction: column-reverse;
  }
}

