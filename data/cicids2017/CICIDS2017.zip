<article class="devsite-article"><style>
      /* Styles inlined from /docs/index.css */
:root {
  --homepage-blue300-opacity-24-background: rgba(138, 180, 248, .24);
}

body[layout=full]:not([template=search]) .devsite-main-content {
  max-width: none;
  padding: 0;
}

.skip-link {
  display: none;
}

.devsite-article h1:first-of-type {
  display: block;
}

devsite-filter input[type=text] {
  border-radius: 10px;
  height: 48px;
  max-width: 700px;
  padding: 10px 42px;
}

li[no-matches] {
  display: none;
}

/* Hero Sections */
.architecture-hero,
.getting-started-hero,
.product-hero {
  margin-bottom: 40px;
}

.getting-started-hero,
.homepage-hero,
.product-hero {
  padding: 0;
}

/* Hero Backgrounds */
.architecture-hero {
  background: url(/docs/images/architecture/hero-banner-right-clear.svg)
     no-repeat top right / 42% auto, var(--devsite-ref-palette--green50);
  background: url(/docs/images/architecture/hero-banner-right-clear.svg)
     no-repeat top right / 42% auto, linear-gradient(90deg,
       var(--devsite-ref-palette--blue50) 0%,
       var(--devsite-ref-palette--green50) 100%);
}

.homepage-hero {
  background: url(/docs/images/hero-transparent.png)
     no-repeat top right / 45% auto;
}

.product-hero {
  background: url(/docs/images/product.png) no-repeat top right
    / 46% auto, var(--devsite-ref-palette--green50);
  background: url(/docs/images/product.png) no-repeat top right
    / 46% auto, linear-gradient(90deg, var(--devsite-ref-palette--blue50) 0%,
      var(--devsite-ref-palette--green50) 100%);
}

.color-scheme--dark .architecture-hero {
  background: url(/docs/images/architecture/hero-banner-right-clear.svg)
     no-repeat top right / 46% auto, var(--devsite-ref-palette--green400);
  background: url(/docs/images/architecture/hero-banner-right-clear.svg)
     no-repeat top right / 46% auto, linear-gradient(90deg,
      var(--devsite-ref-palette--blue400) 0%,
      var(--devsite-ref-palette--green400) 100%);
}

.color-scheme--dark .product-hero {
  background: url(/docs/images/product.png) no-repeat top right
    / 46% auto, var(--devsite-ref-palette--green400);
  background: url(/docs/images/product.png) no-repeat top right
    / 46% auto,
    linear-gradient(90deg, var(--devsite-ref-palette--blue400) 0%,
      var(--devsite-ref-palette--green400) 100%);
}

/* Docs Hero Styles */
.docs-hero .devsite-landing-row-item-description {
  padding-block: 40px !important;
}

.docs-hero .devsite-landing-row-item-description,
.docs-hero .devsite-landing-row-item-body {
  display: flex;
  justify-content: center;
}

.docs-hero h3 {
  font: var(--devsite-h1-font);
}

/* Landing Row elements */
.devsite-landing-row-description {
  --devsite-landing-row-description-font-size: 16px;
}

.devsite-landing-row-cards {
  --devsite-description-content-font: var(--devsite-card-summary-font);
  --devsite-h2-font: var(--devsite-card-heading-font);
}

.devsite-landing-row .category-section-card h3,
.devsite-landing-row .category-section-card h4,
.devsite-landing-row .category-section-card-title {
  font: var(--devsite-card-heading-font);
}

.devsite-card .button-flat {
  margin: -8px;
}

.devsite-landing-row-item-icon-container[background='light-blue'] {
  --devsite-background-color: var(--devsite-ref-palette--blue100);
  --devsite-foreground-color: var(--devsite-ref-palette--blue600);
}

.color-scheme--dark .devsite-landing-row-item-icon-container[background='light-blue'] {
  --devsite-background-color: var(--devsite-ref-palette--grey900);
  --devsite-foreground-color: #fff;
}

.devsite-landing-row-item-icon-container[background][size='medium'] {
  --devsite-icon-canvas-size: 40px;
  --devsite-icon-size: 24px;
  margin-bottom: 20px;
}

/* Rating Info */
.rating-info-section {
  display: flex;
  list-style: none;
  margin-inline-end: 12px;
}

.rating-info-section .rating-star {
  color: var(--devsite-ref-palette--yellow400);
  font-size: 14px;
  line-height: 1.7;
}

/* More Info / Chips */
.more-info-container {
  display: flex;
  flex-wrap: wrap;
  font-size: 12px;
}

.docs-landing-page .more-info-container span {
  color: var(--tenant-secondary-text-color);
  font-size: 12px;
  margin-inline-end: 12px;
}

.chips-container {
  margin-top: 4px;
}

li + li .devsite-label {
  margin-top: 16px;
}

/* Docs Spotlight Card List */
.docs-spotlight-card-list .devsite-landing-row-item:first-of-type {
  background: var(--devsite-ref-palette--blue50);
  border-color: var(--devsite-ref-palette--blue300);
}

.docs-spotlight-card-list .devsite-landing-row-item:nth-of-type(2) {
  background: var(--devsite-ref-palette--green50);
  border-color: var(--devsite-ref-palette--green300);
}

.color-scheme--dark .docs-spotlight-card-list .devsite-landing-row-item:nth-of-type(n) {
  background: 0;
  border: var(--devsite-card-border);
}

/* Category Page Styling */
.docs-category-page article,
.docs-product-page article {
  padding-top: 0 !important;
  padding-right: 0 !important;
  padding-left: 0 !important;
}

.docs-category-page .devsite-article-body,
.docs-product-page .devsite-article-body {
  margin-top: 0;
}

.docs-category-page .devsite-banner,
.docs-product-page .devsite-banner {
  margin: 0;
}

.docs-category-page .devsite-article-meta[role='navigation'],
.docs-product-page .devsite-article-meta[role='navigation'] {
  display: none;
}

.docs-category-page h3 button,
.docs-product-page h3 button {
  display: none;
}

.category-expandable h3.expandable-header,
.devsite-landing-row-header-text h2,
.devsite-landing-row-header-text h2 .devsite-heading,
.devsite-landing-row-header-text .product-section-heading,
.devsite-landing-row-inner .devsite-heading {
  font: 500 28px/36px var(--devsite-heading-font-family);
}

.devsite-landing-row-inner .free-trial-description .devsite-heading {
  font: 500 18px var(--devsite-heading-font-family);
}

.category-expandable h4.expandable-section-header {
  font: 400 24px/30px var(--devsite-heading-font-family);
}

.category-expandable devsite-expandable {
  border: var(--tenant-primary-border);
  border-radius: 8px;
  margin-bottom: 24px;
}

.category-expandable .expandable-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 24px 20px 0 20px !important;
  color: var(--tenant-primary-text-color);
}

.category-expandable .expandable-section-header {
  margin: 40px 20px 0 20px !important;
}

.category-expandable:not(.getting-started-expandable) .expandable-header::before {
  content: none !important;
}

.category-expandable .expandable-header::after {
  content: 'expand_more';
  font: 400 36px 'Material Icons';
  color: var(--devsite-link-color);
}

.category-expandable devsite-expandable[expanded] .expandable-header::after {
  content: 'expand_less';
}

.category-expandable :focus .expandable-header::after {
  background: var(--devsite-link-color);
  border-radius: 50%;
  color: var(--devsite-inverted-text-color);
}

.category-expandable .expandable-description {
  margin: 18px 80px 20px 20px;
  color: var(--tenant-primary-text-color);
  font: 400 16px var(--devsite-primary-font-family);
}

.category-expandable devsite-expandable[expanded] .expandable-cards {
  display: grid !important;
  grid: auto-flow / repeat(auto-fill, minmax(210px, 1fr));
  padding: 20px;
}

.expandable-card {
  display: block !important;
}

.docs-category-page .category-expandable .list {
  display: block;
  width: 100%;
  margin: 16px 0;
}

.category-section devsite-pagination {
  margin-top: 32px;
}

.category-expandable .category-section-description {
  margin-bottom: 24px;
}

.category-section-card-custom-icon:hover {
  filter: invert(39%) sepia(100%) saturate(3258%) hue-rotate(202deg) brightness(93%) contrast(95%);
}

.category-section-card-custom-icon {
  width: 40px;
}

.category-section-card-description {
  font: var(--devsite-card-summary-font);
  color: var(--devsite-card-summary-color);
}

.category-section-card-description .material-icons {
  font-size: 18px;
  margin-inline-start: 4px;
  vertical-align: middle;
}

.category-expandable-search {
  max-width: 100% !important;
  padding: 20px !important;
}

.category-expandable-search + span:before {
  padding-top: 12px;
}

/* Product Page Styling */

.filter-section-heading button {
  display: none;
}

.filter-section-heading,
.filter-section-description {
  text-align: center;
}

.product-section-filter-card .more-info-container span {
  color: var(--tenant-secondary-text-color);
  font-size: 12px;
  margin-right: 12px;
}

.product-section-filter-card .more-info-container i {
  color: var(--devsite-ref-palette--yellow400);
  font-size: 14px;
  line-height: 1.7;
}

.product-section-filter-card .more-info-container {
  margin-top: 8px;
}

.product-list-card-items {
  list-style: none;
  padding: 0;
}

.product-list-card-item {
  margin-block: 8px;
}

.product-list-card-item a p {
  color: var(--devsite-link-color);
  line-height: normal;
}

.product-filter-hidden-tag {
  display: none;
}

.product-filter-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-block: 20px;
  gap: 12px;
}

.product-filter-section input {
  display: block;
  height: 0;
  opacity: 0;
  width: 0;
}

.product-filter-section label {
  border: var(--devsite-primary-border);
  border-radius: 8px;
  display: block;
  padding: 5px 16px;
  font: 500 14px/20px var(--devsite-primary-font-family);
  transition: background-color .2s, border .2s, box-shadow .2s;
  user-select: none;
}

.product-filter-section label:hover {
  background: var(--devsite-background-3);
}

.product-filter-section input:focus + label,
.product-filter-section label:focus,
.product-filter-section label:active {
  background: var(--devsite-background-4);
}

.product-filter-section input:focus + label,
.product-filter-section label:focus {
  border-color: var(--devsite-primary-text-color);
}

.product-filter-section input:checked + label {
  background: var(--devsite-button-primary-background);
  border-color: var(--devsite-button-primary-background);
  color: var(--tenant-inverted-text-color);
}

.product-filter-section input:checked + label:before {
  content: 'check';
  display: inline-block;
  font: 18px 'Material Icons';
  margin-inline: -6px 6px;
  margin-top: -2px;
  vertical-align: middle;
}

.product-filter-section input:checked + label:hover {
  box-shadow: var(--devsite-button-box-shadow-active);
}

.product-filter-section input:checked:focus + label,
.product-filter-section input:checked + label:focus,
.product-filter-section input:checked + label:active {
  background: var(--devsite-button-primary-background-active);
  border-color: var(--devsite-button-primary-background-active);
}

.product-section-cards.list {
  margin-top: 32px;
}

/* Cloud Docs Homepage Styles */

.devsite-article-body .cloud-hero,
.devsite-article-body .cloud-hero-search {
  background: var(--devsite-ref-palette--blue50);
}

.color-scheme--dark .cloud-hero,
.color-scheme--dark .cloud-hero-search {
  background: var(--homepage-blue300-opacity-24-background);
}

.devsite-article-body .cloud-hero-search {
  padding: 0;
}

.devsite-article-body .cloud-hero-search h1 {
  color: var(--devsite-primary-text-color);
  font-size: 56px;
  line-height: 60px;
  margin: 0;
}

.cloud-hero .devsite-landing-row-group {
  max-width: 748px;
}

.cloud-hero-card {
  text-align: center;
}

.cloud-hero-card .devsite-landing-row-item-body h3 {
  font: 500 16px var(--devsite-headline-font-family);
  margin-bottom: 0;
  line-height: 24px;
}

.cloud-hero-card .devsite-landing-row-item-description[icon-position=top] {
  align-items: center;
}

.cloud-hero-card .devsite-landing-row-item-icon-container {
  height: 24px;
  margin: 0 0 16px;
  width: 24px;
}

.cloud-hero-card .devsite-landing-row-item-icon {
  height: 24px;
  margin: 0;
  width: 24px;
}

.clouddocs-homepage .devsite-top-logo-row-middle devsite-search {
  display: none;
}

.devsite-landing-row-inner .devsite-landing-row-html .devsite-header-billboard-homepage {
  padding: 40px 24px;
  text-align: center;
}

.clouddocs-homepage .devsite-header-billboard-search {
  padding: 0 24px 40px;
  text-align: center;
}

.clouddocs-homepage .devsite-header-billboard-search devsite-search input.devsite-search-field {
  background: var(--devsite-input-background);
  border-radius: 16px;
}

.clouddocs-homepage .devsite-header-billboard-search devsite-search,
.clouddocs-homepage .devsite-header-billboard-search devsite-search .devsite-searchbox {
  --devsite-search-border-radius: 16px;
  --devsite-searchbox-background: var(--devsite-input-background);
  --devsite-searchbox-background-active: var(--devsite-input-background);
  margin: 0;
  max-width: 900px;
  width: 100%;
}

.clouddocs-homepage .devsite-header-billboard-search devsite-search .devsite-popout-result,
.clouddocs-homepage .devsite-header-billboard-search devsite-search .devsite-popout .devsite-result-item a {
  color: var(--devsite-primary-text-color);
}

.clouddocs-homepage .devsite-header-billboard-search devsite-search .devsite-popout .devsite-popout-result .button-white:focus,
.clouddocs-homepage .devsite-header-billboard-search devsite-search .devsite-popout .devsite-popout-result .button-white:hover {
  background: var(--devsite-button-primary-background-hover);
  color: var(--devsite-link-color);
}

.clouddocs-homepage .devsite-header-billboard-search devsite-search .devsite-popout .devsite-popout-result .button {
  color: var(--devsite-header-link-color);
}

/*Cloud Docs Filter section*/
devsite-catalog .catalog-checkbox-controls-container {
  border: 0;
  padding: 0 12px 12px;
}

devsite-catalog .catalog-checkbox-controls-group {
  padding: 0;
}

devsite-catalog .catalog-checkbox-controls-title {
  background: var(--devsite-background-3);
  border: 0;
  border-radius: 100px;
  color: var(--devsite-primary-text-color);
  display: flex;
  margin-block: 4px;
  padding: 8px 16px;
}

devsite-catalog .catalog-checkbox-controls-group > devsite-pagination .button,
devsite-catalog .catalog-checkbox-controls-subtitle,
devsite-catalog .catalog-container .catalog-clear-group-checkboxes-button,
devsite-catalog .catalog-container .catalog-select-group-checkboxes-button {
  display: none;
}

devsite-catalog input[type=checkbox] {
  opacity: 0;
}

devsite-catalog .catalog-checkbox-container {
  align-self: stretch;
  border-radius: 100px;
  display: flex;
  flex: 1 0;
  margin-block: 4px;
  padding: 8px 21px;
  width: 100%;
}

devsite-catalog .catalog-checkbox-container:has(input[type=checkbox]:checked) {
  --devsite-catalog-label-color: var(--devsite-link-color);
  background: var(--devsite-ref-palette--blue50);
}

.color-scheme--dark devsite-catalog .catalog-checkbox-container:has(input[type=checkbox]:checked) {
  background: 0;
  border: var(--devsite-card-border);
  color: var(--devsite-primary-text-color);
  padding: 7px 20px;
}

devsite-catalog .catalog-checkbox-container:has(input[type=checkbox]:focus) {
  background: var(--devsite-background-3);
  color: var(--devsite-primary-text-color);
}

.color-scheme--dark devsite-catalog .catalog-checkbox-container:has(input[type=checkbox]:focus) {
  background: var(--devsite-background-3);
}

devsite-catalog .catalog-checkbox-label,
.color-scheme--dark .catalog-checkbox-container:has(input[type=checkbox]:checked) .catalog-checkbox-label {
  --devsite-catalog-label-color: var(--devsite-primary-text-color);
  --devsite-catalog-label-font: 400 15px/20px var(--devsite-primary-font-family);
}

.catalog-checkbox-container:has(input[type=checkbox]:checked) .catalog-checkbox-label {
  --devsite-catalog-label-color: var(--devsite-link-color);
}

devsite-catalog .catalog-filter-bar {
  max-width: none;
}

devsite-catalog .catalog-checkbox-controls-title::before {
  content: 'menu';
  font-family: 'Material Icons';
  font-size: 24px;
  padding-inline-end: 6px;
  text-transform: none;
}

/*Cloud Docs Cards section*/
.devsite-card-group .devsite-card-content {
  margin-top: 8px;
  order: 1;
}

.devsite-card-group .devsite-card-section {
  order: -1;
}

.devsite-card-content-wrapper .devsite-card-section .devsite-card-icons {
  padding: 16px 16px 0;
}

/*Cloud Docs What's New section*/

.cloud-releases .devsite-landing-row-item-media {
  aspect-ratio: 16 / 9;
  overflow: hidden;
}

/* Media Queries */

@media screen and (min-width: 841px) {
  .list:not(.getting-started-list) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding: 0;
    grid-gap: var(--devsite-landing-row-item-gap);
  }
}

@media screen and (max-width: 1252px) {
  .homepage-hero {
    background: 0;
  }
}

@media screen and (max-width: 840px) {
  .devsite-landing-row-header {
    display: flex;
  }
}

@media screen and (max-width: 400px) {
  .devsite-landing-row-header {
    display: block;
  }
}

@media screen and (max-width: 840px) {
  .docs-hero {
    background: var(--devsite-ref-palette--green50);
    background: linear-gradient(90deg, var(--devsite-ref-palette--blue50) 0%,
      var(--devsite-ref-palette--green50) 100%);
  }

  .color-scheme--dark .docs-hero {
    background: var(--devsite-ref-palette--green400);
    background: linear-gradient(90deg, var(--devsite-ref-palette--blue400) 0%,
      var(--devsite-ref-palette--green400) 100%);
  }
}

@media screen and (max-width: 600px) {
  .devsite-article-body .cloud-hero-search h1 {
    font-size: 10vw;
  }
}
